[Unit]
Description=Gunicorn daemon for TradeFlow (Django)
After=network.target postgresql.service

[Service]
Type=notify
User=www-data
Group=www-data
WorkingDirectory=/var/www/html/tradeflow/backend
Environment="PATH=/var/www/html/tradeflow/backend/.venv/bin"
EnvironmentFile=/var/www/html/tradeflow/backend/.env

ExecStart=/var/www/html/tradeflow/backend/.venv/bin/gunicorn \
    --workers 3 \
    --bind 127.0.0.1:8010 \
    --timeout 60 \
    config.wsgi:application

ExecReload=/bin/kill -s HUP $MAINPID
KillMode=mixed
TimeoutStopSec=5
PrivateTmp=true
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
