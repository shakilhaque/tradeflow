# Copy this file to backend/.env and fill in real values.

SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Single database for the whole app. Password special chars must be URL-encoded.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nsl_pos

APP_NAME=NSL-POS

# Email (dev: console prints instead of sending)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@nsl-pos.local

FRONTEND_URL=http://localhost:3050
BACKEND_BASE_URL=http://127.0.0.1:8003
